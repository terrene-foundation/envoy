# Envoy — gitignore

# Environments
.env
.env.local
.env.*.local
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/
*.egg

# Rust
target/
**/*.rs.bk
Cargo.lock

# Node (if SKILL.md ingest needs it)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Platform
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.iml

# Secrets (never commit)
*.pem
*.key
*-secret.*
trust-vault/
shamir-shards/

# Build artifacts
*.log
coverage/
.coverage
.coverage.*

# Envoy-specific
envoy-data/
envoy-ledger/
*.ledger.jsonl

# Session state — never public
.session-notes

# Internal research — lives in ~/repos/dev/envoy-internal-research/ (sibling
# directory, outside this repo). Anything added inside workspaces/ here is
# considered public-safe and gets tracked; see workspaces/README.md.
