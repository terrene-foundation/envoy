# Envoy — gitignore

# Environments
.env
.env.local
.env.*.local
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/
*.egg

# Rust
target/
**/*.rs.bk
Cargo.lock

# Node (if SKILL.md ingest needs it)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Platform
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.iml

# Secrets (never commit)
*.pem
*.key
*-secret.*
trust-vault/
shamir-shards/

# Build artifacts
*.log
coverage/
.coverage
.coverage.*

# Envoy-specific
envoy-data/
envoy-ledger/
*.ledger.jsonl

# Session state — never public
.session-notes

# COC runtime + learning state — per-repo, contains absolute filesystem
# paths from the user's local machine and free-text agent observations.
# Never tracked publicly. Preserved across /sync per template convention.
**/.claude/learning/
**/.claude/scheduled_tasks.lock
**/.claude/worktrees/

# Internal research — pulled back into the repo for working speed + clarity
# (per user decision 2026-04-21). Everything under workspaces/internal/ is
# internal-voice: sharp claims about third parties, strategic positioning,
# unsanitized analysis. It is NEVER committed. The public-safe deep-analysis
# output lives at workspaces/phase-00-alignment/01-analysis/ and is tracked.
#
# If you move a file out of workspaces/internal/ into any tracked path, you
# MUST rewrite it to Foundation voice first. See workspaces/README.md and
# the communications mandate in rules/terrene-naming.md.
workspaces/internal/
